-- ============================================================================
-- LAYER 1: CORE HUB (Tracking the Origin of the DNA)
-- ============================================================================
CREATE TABLE biological_samples (
    sample_id SERIAL PRIMARY KEY,                   -- Unique ID generated automatically
    internal_sample_name VARCHAR(100) NOT NULL UNIQUE, -- E.g., "LAB-2026-TUMOR01"
    organism VARCHAR(100) NOT NULL DEFAULT 'Homo sapiens',
    tissue_source VARCHAR(100) NOT NULL,            -- E.g., "Blood", "Liver Biopsy", "Saliva"
    extraction_method VARCHAR(100),                 -- E.g., "Qiagen DNeasy Kit"
    collection_date DATE NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- ============================================================================
-- LAYER 2: EXTERNAL FILE TRACKER (Points to your hard drive folders)
-- ============================================================================
CREATE TABLE genomic_files (
    file_id SERIAL PRIMARY KEY,
    sample_id INT NOT NULL REFERENCES biological_samples(sample_id) ON DELETE CASCADE,
    file_type VARCHAR(20) NOT NULL,                 -- E.g., "FASTQ", "FASTA", "BAM", "VCF"
    absolute_file_path TEXT NOT NULL UNIQUE,        -- E.g., "/mnt/data/seq_raw/sample01_R1.fastq.gz"
    file_size_gb NUMERIC(6,2),                      -- Tracks file footprint
    md5_checksum VARCHAR(32),                       -- Verifies the file isn't corrupted
    is_archived BOOLEAN DEFAULT FALSE
);

-- ============================================================================
-- LAYER 3: VARIANT CALL DATA (For actual mutation discovery)
-- ============================================================================
CREATE TABLE variant_calls (
    variant_id BIGSERIAL PRIMARY KEY,               -- BIGSERIAL allows billions of mutations
    sample_id INT NOT NULL REFERENCES biological_samples(sample_id) ON DELETE CASCADE,
    chromosome VARCHAR(5) NOT NULL,                 -- E.g., "chr1", "chrX"
    genomic_position INT NOT NULL,                  -- Physical coordinate on the chromosome
    reference_allele TEXT NOT NULL,                  -- Original base (e.g., "A")
    alternate_allele TEXT NOT NULL,                  -- Mutated base (e.g., "G")
    mutation_type VARCHAR(50),                      -- E.g., "SNV", "Insertion", "Deletion"
    quality_score NUMERIC(6,2),                     -- Sequencing confidence score
    filter_status VARCHAR(20) DEFAULT 'PASS'        -- E.g., "PASS", "LowQual"
);

-- ============================================================================
-- LAYER 4: FLEXIBLE PHENOTYPES (The future-proof "catch-all" container)
-- ============================================================================
CREATE TABLE clinical_phenotypes (
    phenotype_id SERIAL PRIMARY KEY,
    sample_id INT NOT NULL REFERENCES biological_samples(sample_id) ON DELETE CASCADE,
    -- JSONB acts like a spreadsheet with infinite invisible columns. 
    -- You can dump different patient data here without changing the database code.
    attributes_json jsonb NOT NULL                  
);

-- ============================================================================
-- PERFORMANCE LAYER: SPEED INDEXES (Critical for massive scaling)
-- ============================================================================
CREATE INDEX idx_samples_name ON biological_samples(internal_sample_name);
CREATE INDEX idx_variants_coords ON variant_calls(chromosome, genomic_position);
CREATE INDEX idx_files_sample ON genomic_files(sample_id);




