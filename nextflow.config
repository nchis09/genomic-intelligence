/*
 * Nextflow configuration for the PGIRL genomic intelligence workflow.
 *
 * Two entry points are provided:
 *   - main.nf            : end-to-end per-sample analysis
 *   - db_update.nf       : update reference data in PostgreSQL from APIs/curated sources
 */

manifest {
    name          = 'pgirl-genomic-intelligence'
    author        = 'GOARN fellowship'
    description   = 'Genomic Epidemic Intelligence System (PGIRL) end-to-end Nextflow DSL2 workflow'
    version       = '0.1.0'
    nextflowVersion = '!>=23.04.0'
}

params {
    // --- Analysis workflow inputs ---
    input_fasta     = 'input/input_FASTA.fasta'
    input_metadata  = 'input/input_metadata.csv'
    outdir          = 'output'

    // --- Database ---
    db_url          = 'postgresql://localhost:5432/pgirl'

    // --- Epi query ---
    use_llm         = false

    // --- DB update ---
    dry_run         = false
    pathogens       = 'ebola'
    sources         = 'all'

    // --- Resource defaults ---
    max_cpus        = 4
    max_memory      = '16.GB'
}

process {
    cpus   = { check_max( 1, 'cpus' ) }
    memory = { check_max( 4.GB, 'memory' ) }
    time   = { check_max( 1.h, 'time' ) }

    errorStrategy = 'finish'
    maxRetries    = 1

    // Default: use the active Python environment (base conda, virtualenv,
    // or system Python with the required packages installed). This avoids
    // forcing a Conda solve when it is not available or broken.
    // Use -profile conda to use the managed pgirl environment instead.
    conda = null
}

profiles {
    // Use the conda environment file. Nextflow will create the env on first
    // run if it does not exist.
    conda {
        process.conda = "${projectDir}/environment.yml"
    }

    // Explicitly disable conda (same as default, kept for clarity)
    no_conda {
        process.conda = null
    }
}

// Keep execution scratch directories under the selected output folder instead
// of the project root.
workDir = "${params.outdir}/work"

// Minimal helper so resource limits are respected if a user lowers them.
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "Note: invalid memory value '${params.max_memory}'"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "Note: invalid time value '${params.max_time}'"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "Note: invalid cpus value '${params.max_cpus}'"
            return obj
        }
    }
}
